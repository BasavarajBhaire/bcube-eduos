{
  "template_version": "pre-print-pilot",
  "canvas": {"width": 2480, "height": 3508, "dpi": 300},
  "safe_margin": 118,
  "templates": {
    "cover": {
      "header_type": "SERIES_HEADER",
      "required": ["official_logo", "series_banner", "age_badge", "book_title", "tagline_ribbon", "illustration_frame", "skill_capsules", "core_pillars", "footer"],
      "prohibited": ["page_number", "publisher_details", "module_groups"],
      "constraints": {"skill_capsules": 6, "core_pillars": 5, "visible_page_number": false}
    },
    "about": {
      "header_type": "BOOK_HEADER",
      "required": ["official_logo", "book_title", "page_title", "illustration_frame", "core_pillars", "footer"],
      "prohibited": ["series_banner", "age_badge", "publisher_details", "module_groups", "page_number", "teacher_panel", "parent_panel"],
      "constraints": {"visible_page_number": false}
    },
    "publisher": {
      "header_type": "MINIMAL_HEADER",
      "required": ["official_logo", "book_title", "publisher_details", "publication_code", "document_id", "footer"],
      "prohibited": ["series_banner", "age_badge", "official_star", "illustration_frame", "illustration_layer", "skill_capsules", "module_groups", "core_pillars", "page_number", "learning_goal", "activity_banner", "teacher_panel", "parent_panel", "isbn"],
      "constraints": {"visible_page_number": false, "illustration": false, "isbn_without_assignment": false}
    },
    "contents": {
      "header_type": "BOOK_HEADER",
      "required": ["official_logo", "book_title", "page_title", "tagline_ribbon", "module_groups", "core_pillars", "footer"],
      "prohibited": ["series_banner", "age_badge", "illustration_frame", "illustration_layer", "teacher_panel", "parent_panel", "page_number", "sticky_note", "callout"],
      "constraints": {"visible_page_number": false, "columns": 2, "show_module_names": true, "show_all_manifest_learning_pages": true}
    },
    "welcome": {
      "header_type": "BOOK_HEADER",
      "required": ["official_logo", "book_title", "page_title", "tagline_ribbon", "illustration_frame", "core_pillars", "footer", "page_number"],
      "prohibited": ["series_banner", "age_badge", "official_star", "teacher_panel", "parent_panel"],
      "constraints": {"visible_page_number": true, "printed_page": 5, "physical_page": 6}
    },
    "meet_star": {
      "header_type": "BOOK_HEADER",
      "required": ["official_logo", "book_title", "page_title", "tagline_ribbon", "official_star", "core_pillars", "footer", "page_number"],
      "prohibited": ["series_banner", "age_badge", "illustration_layer", "teacher_panel", "parent_panel"],
      "constraints": {"visible_page_number": true, "printed_page": 6, "physical_page": 7, "official_star": 1}
    },
    "lesson": {
      "header_type": "LESSON_HEADER",
      "required": ["official_logo", "book_title", "page_title", "learning_goal", "activity_banner", "illustration_frame", "teacher_panel", "parent_panel", "page_number"],
      "prohibited": ["series_banner", "age_badge", "official_star"],
      "constraints": {"visible_page_number": true, "page_specific_content": true, "default_star": false}
    },
    "back_cover": {
      "header_type": "BOOK_HEADER",
      "required": ["official_logo", "book_title", "tagline_ribbon", "footer"],
      "prohibited": ["age_badge", "page_number", "teacher_panel", "parent_panel", "module_groups"],
      "constraints": {"visible_page_number": false, "single_true_back_cover": true}
    }
  }
}
