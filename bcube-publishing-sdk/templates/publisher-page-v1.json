{
  "template_version": "publisher-page-v1.0",
  "page_type": "publisher",
  "header_type": "MINIMAL_HEADER",
  "canvas": {"width": 2480, "height": 3508, "dpi": 300},
  "safe_margin": 118,
  "bounds": {
    "logo": [150, 90, 500, 340],
