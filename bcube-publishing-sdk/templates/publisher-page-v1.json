    "book_title_line_2": [520, 184, 2290, 310],
    "level": [700, 320, 2110, 405],
    "page_title": [300, 515, 2180, 655],
    "divider": [300, 700, 2180, 712],
    "publisher_panel": [250, 815, 2230, 1530],
    "identifiers_panel": [250, 1600, 2230, 2165],
    "rights_panel": [250, 2240, 2230, 2945],
    "footer": [0, 3250, 2480, 3508]
  },
  "colours": {
    "background": "#FFFDF8",
    "navy": "#163B65",
    "purple": "#643595",
    "blue": "#1768B3",
    "pink": "#ED2F7C",
    "gold": "#F4B61A",
    "panel": "#F7F3FA",
    "panel_alt": "#EEF6FC",
    "line": "#D8C8E7",
    "text": "#343434",
