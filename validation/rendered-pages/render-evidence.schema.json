{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bcubefutureacademy.in/schemas/render-evidence.schema.json",
  "title": "BCube Render Evidence Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "page_id",
    "page_type",
    "book_key",
    "artifact_path",
    "composition",
    "component_evidence",
    "text_evidence",
    "human_approval"
  ],
  "properties": {
    "page_id": {"type": "string", "minLength": 3},
    "page_type": {"enum": ["cover", "about", "publisher", "contents", "back_cover"]},
    "book_key": {"type": "string", "pattern": "^[a-z0-9-]+/[a-z0-9-]+$"},
    "artifact_path": {"type": "string", "minLength": 1},
    "composition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "full_page_ai_generation", "single_flat_page"],
      "properties": {
        "engine": {"const": "bcube-publishing-sdk"},
        "engine_version": {"type": "string"},
        "full_page_ai_generation": {"const": false},
        "single_flat_page": {"const": true},
        "illustration_layer_path": {"type": "string"},
        "illustration_layer_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "component_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component", "bounds", "template_bounds"],
        "properties": {
          "component": {"type": "string", "minLength": 1},
          "source_path": {"type": "string"},
          "approved_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "bounds": {
            "type": "array", "prefixItems": [{"type":"integer"},{"type":"integer"},{"type":"integer"},{"type":"integer"}], "minItems": 4, "maxItems": 4
          },
          "template_bounds": {
            "type": "array", "prefixItems": [{"type":"integer"},{"type":"integer"},{"type":"integer"},{"type":"integer"}], "minItems": 4, "maxItems": 4
          },
          "allow_overlap": {"type": "boolean", "default": false}
        }
      }
    },
    "text_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["detector", "detected_text"],
      "properties": {
        "detector": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": {"type": "string", "minLength": 1},
            "version": {"type": "string", "minLength": 1},
            "evidence_path": {"type": "string"}
          }
        },
        "detected_text": {"type": "array", "items": {"type": "string"}}
      }
    },
    "human_approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer", "approved_on", "status", "artifact_sha256"],
      "properties": {
        "reviewer": {"type": "string", "minLength": 3},
        "approved_on": {"type": "string", "format": "date"},
        "status": {"const": "APPROVED"},
        "artifact_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "notes": {"type": "string"}
      }
    }
  }
}
