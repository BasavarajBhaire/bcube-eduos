{
  "$schema": "../schemas/build-profile.schema.json",
  "id": "GOLD-PRINT",
  "version": "1.0.0",
  "status": "active",
  "outputType": "print-workbook-page",
  "page": {
    "sizeMm": {"width": 210, "height": 297},
    "orientation": "portrait",
    "dpi": 300,
    "bleedMm": 3,
    "safeMarginMm": 10
  },
  "requiredPromptSections": [
    "technicalSpecification",
    "brandSpecification",
    "layoutSpecification",
    "characterSpecification",
    "illustrationSpecification",
    "educationalObjective",
    "teacherGuidance",
    "childActivity",
    "negativeConstraints"
  ],
  "hardGates": [
    "noUnresolvedPlaceholders",
    "noModuleReferences",
    "exactTextPreserved",
    "protectedActivityArea",
    "brandResolved",
    "characterResolved",
    "printGeometryResolved"
  ]
}
