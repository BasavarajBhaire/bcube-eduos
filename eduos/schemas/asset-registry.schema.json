{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bcubefutureacademy.in/schemas/asset-registry.schema.json",
  "title": "BCube EduOS Asset Registry",
  "type": "object",
  "required": ["registry_version", "assets"],
  "properties": {
    "registry_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["asset_id", "family", "variant", "version", "type", "status", "path", "sha256"],
        "properties": {
          "asset_id": {"type": "string", "pattern": "^[A-Z0-9_]+\\.[A-Z0-9_]+\\.V[0-9]+\\.[0-9]+\\.[0-9]+$"},
          "family": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
          "variant": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
          "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
          "type": {"enum": ["BRAND", "CHARACTER", "SCENE", "ACTIVITY", "ICON", "DECORATION", "FONT"]},
          "status": {"enum": ["DRAFT", "REVIEW", "GOLD", "DEPRECATED", "ARCHIVED"]},
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
          "git_blob_sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
          "mime_type": {"type": "string"},
          "width": {"type": "integer", "minimum": 1},
          "height": {"type": "integer", "minimum": 1},
          "dpi": {"type": "integer", "minimum": 72},
          "approved_by": {"type": "string"},
          "dependencies": {"type": "array", "items": {"type": "string"}, "default": []}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
