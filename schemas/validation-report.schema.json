{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bcubefutureacademy.in/schemas/validation-report.schema.json",
  "title": "BCube Validation Report",
  "type": "object",
  "required": ["artifact_id", "artifact_type", "version", "status", "gold_score", "critical_defects", "checks"],
  "properties": {
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_type": {"enum": ["rule", "fragment", "template", "prompt", "illustration", "page", "book", "release-package"]},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "status": {"enum": ["pass", "conditional-pass", "rework", "reject"]},
    "gold_score": {"type": "number", "minimum": 0, "maximum": 100},
    "critical_defects": {"type": "integer", "minimum": 0},
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["validation_id", "result", "severity"],
        "properties": {
          "validation_id": {"type": "string"},
          "result": {"enum": ["pass", "fail", "not-applicable"]},
          "severity": {"enum": ["critical", "major", "minor", "cosmetic"]},
          "evidence": {"type": "string"},
          "remediation": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "approved_by": {"type": "string"},
    "approved_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "pass"}}},
      "then": {
        "properties": {
          "gold_score": {"minimum": 90},
          "critical_defects": {"const": 0}
        }
      }
    }
  ],
  "additionalProperties": false
}