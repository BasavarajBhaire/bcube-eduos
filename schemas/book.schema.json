{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bcubefutureacademy.in/schemas/book.schema.json",
  "title": "BCube Book Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["book_id", "title", "series", "level", "version", "pages"],
  "properties": {
    "book_id": {"type": "string", "pattern": "^[A-Z0-9_-]+$"},
    "title": {"type": "string", "minLength": 1},
    "series": {"type": "string", "minLength": 1},
    "level": {"enum": ["Nursery 3+", "LKG 4+", "UKG 5+", "Grade 1+"]},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "language": {"type": "string", "default": "en-IN"},
    "publisher": {"type": "string", "const": "BCube Future Academy"},
    "page_count": {"type": "integer", "minimum": 1},
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "page.schema.json"}
    }
  }
}
