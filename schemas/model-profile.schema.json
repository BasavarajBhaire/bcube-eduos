{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bcubefutureacademy.in/schemas/model-profile.schema.json",
  "title": "BCube Image Model Profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["profileId", "version", "status", "promptStyle", "outputDefaults", "validation"],
  "properties": {
    "profileId": {"type": "string", "minLength": 3},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "status": {"enum": ["draft", "active", "deprecated", "archived"]},
    "purpose": {"type": "string"},
    "promptStyle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "sectionOrder", "requireSelfContainedPrompt", "allowRuleReferences", "allowPlaceholders"],
      "properties": {
        "format": {"type": "string"},
        "sectionOrder": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "requireSelfContainedPrompt": {"type": "boolean"},
        "allowRuleReferences": {"type": "boolean"},
        "allowPlaceholders": {"type": "boolean"},
        "preferPositiveInstructionsBeforeNegativeConstraints": {"type": "boolean"},
        "repeatCriticalIdentityDetails": {"type": "boolean"}
      }
    },
    "outputDefaults": {"type": "object"},
    "validation": {
      "type": "object",
      "required": ["requireExactTextBlock", "requireNegativeConstraints", "requirePromptFingerprint", "rejectUnresolvedTokens"],
      "properties": {
        "requireExactTextBlock": {"type": "boolean"},
        "requireNegativeConstraints": {"type": "boolean"},
        "requirePromptFingerprint": {"type": "boolean"},
        "rejectUnresolvedTokens": {"type": "boolean"}
      }
    }
  }
}
