{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bcubefutureacademy.in/schemas/prompt-ir.schema.json",
  "title": "BCube Prompt Intermediate Representation",
  "type": "object",
  "required": ["promptId", "book", "page", "publishing", "design", "education", "characters", "illustration", "activity", "validation"],
  "properties": {
    "promptId": {"type": "string", "pattern": "^BC-GP-[A-Z0-9-]+$"},
    "book": {"type": "object"},
    "page": {"type": "object"},
    "publishing": {"type": "object"},
    "design": {"type": "object"},
    "education": {"type": "object"},
    "teaching": {"type": "object"},
    "parent": {"type": "object"},
    "characters": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "illustration": {"type": "object"},
    "activity": {"type": "object"},
    "exactText": {"type": "array", "items": {"type": "string"}},
    "negativeConstraints": {"type": "array", "items": {"type": "string"}},
    "validation": {"type": "object"}
  },
  "additionalProperties": false
}
