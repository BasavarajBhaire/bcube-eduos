{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bcubefutureacademy.in/schemas/page.schema.json",
  "title": "BCube Page Specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "book_id",
    "page_number",
    "page_type",
    "page_title",
    "age_level",
    "learning_objective",
    "competencies",
    "activity",
    "template_id"
  ],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^3\\.[0-9]+\\.[0-9]+$"},
    "book_id": {"type": "string", "minLength": 3},
    "unit_id": {"type": ["string", "null"]},
    "page_number": {"type": "integer", "minimum": 1},
    "page_type": {
      "type": "string",
      "enum": ["cover", "copyright", "contents", "welcome", "learning", "activity", "review", "assessment", "certificate", "back-cover"]
    },
    "page_title": {"type": "string", "minLength": 1, "maxLength": 80},
    "age_level": {"type": "string", "enum": ["Nursery", "LKG", "UKG", "Grade 1+"]},
    "learning_objective": {"type": "string", "minLength": 8, "maxLength": 240},
    "competencies": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["Curiosity", "Communication", "Creativity", "Critical Thinking", "Collaboration", "Confidence", "Character"]
      }
    },
    "future_skill": {"type": ["string", "null"]},
    "activity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instruction", "response_mode"],
      "properties": {
        "instruction": {"type": "string", "minLength": 1, "maxLength": 220},
        "response_mode": {
          "type": "string",
          "enum": ["observe", "speak", "trace", "draw", "colour", "match", "circle", "tick", "write", "cut-and-paste", "perform"]
        },
        "materials": {"type": "array", "items": {"type": "string"}},
        "assessment_evidence": {"type": ["string", "null"]}
      }
    },
    "template_id": {"type": "string", "pattern": "^TPL-[A-Z]+-[0-9]{3}$"},
    "illustration_brief": {"type": ["string", "null"]},
    "teacher_prompt": {"type": ["string", "null"]},
    "parent_prompt": {"type": ["string", "null"]},
    "status": {"type": "string", "enum": ["DRAFT", "REVIEW", "FINAL"], "default": "DRAFT"}
  }
}