{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bcubefutureacademy.in/schemas/asset-manifest.schema.json",
  "title": "BCube Asset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "assetId",
    "assetType",
    "name",
    "version",
    "status",
    "owner",
    "dependencies",
    "validationProfile",
    "compilerExpansion",
    "source"
  ],
  "properties": {
    "assetId": {
      "type": "string",
      "pattern": "^[A-Z]{2,8}-[A-Z0-9-]{3,64}$"
    },
    "assetType": {
      "type": "string",
      "enum": [
        "character",
        "template",
        "rule",
        "fragment",
        "brand",
        "logo",
        "typography",
        "layout",
        "illustration-style",
        "activity",
        "learning-objective",
        "assessment-rubric",
        "teacher-persona",
        "parent-persona",
        "build-profile"
      ]
    },
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "status": {
      "type": "string",
      "enum": ["draft", "review", "approved", "gold-certified", "deprecated", "archived"]
    },
    "owner": {"type": "string", "minLength": 1},
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["assetId", "versionRange"],
        "properties": {
          "assetId": {"type": "string"},
          "versionRange": {"type": "string"},
          "required": {"type": "boolean", "default": true}
        }
      }
    },
    "validationProfile": {"type": "string", "minLength": 1},
    "compilerExpansion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "sourcePath"],
      "properties": {
        "mode": {"type": "string", "enum": ["inline", "parameterized", "metadata-only"]},
        "sourcePath": {"type": "string", "minLength": 1},
        "requiredFields": {"type": "array", "items": {"type": "string"}}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "format"],
      "properties": {
        "path": {"type": "string"},
        "format": {"type": "string", "enum": ["json", "yaml", "markdown", "image", "svg"]},
        "checksum": {"type": "string"}
      }
    },
    "tags": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "createdAt": {"type": "string", "format": "date-time"},
    "updatedAt": {"type": "string", "format": "date-time"}
  }
}
